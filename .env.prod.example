# --- GitHub source (build images depuis le repo privé) ---
GITHUB_REPO=your-org/senlegal
GITHUB_REF=main
# PAT classique (scope `repo`) ou fine-grained (Contents: Read)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tag/registre des images produites localement
REGISTRY=senlegal
IMAGE_TAG=latest

# --- Domaines & TLS (Caddy) ---
WEB_DOMAIN=senlegal.sn
API_DOMAIN=api.senlegal.sn
FILES_DOMAIN=files.senlegal.sn
ACME_EMAIL=ops@senlegal.sn

# --- URLs publiques (utilisées par les apps) ---
APP_PUBLIC_URL=https://api.senlegal.sn
WEB_PUBLIC_URL=https://senlegal.sn
CORS_ORIGINS=https://senlegal.sn
NUXT_PUBLIC_API_BASE=https://api.senlegal.sn/api
S3_PUBLIC_URL=https://files.senlegal.sn
MINIO_CONSOLE_PUBLIC_URL=

# --- PostgreSQL ---
POSTGRES_USER=senlegal
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=senlegal

# --- Secrets app (obligatoires) ---
JWT_SECRET=please-change-this-in-production-32chars-min
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@senlegal.sn
ADMIN_PASSWORD=ChangeMeNow!2026
ADMIN_NAME=Administrateur SenLégal
SEED_ON_BOOT=true
AI_ADMIN_TOKEN=change-me

# --- AI / Ollama ---
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_KEEP_ALIVE=30m
MODEL_NAME=gemma4:31b-cloud
AI_CORS_ORIGINS=https://api.senlegal.sn

# --- S3 / MinIO ---
S3_ACCESS_KEY=senlegal
S3_SECRET_KEY=change-me-strong-secret
S3_BUCKET=senlegal
S3_REGION=us-east-1

# --- SMTP prod ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SenLégal <no-reply@senlegal.sn>

# --- PayDunya ---
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=live
PAYDUNYA_STORE_NAME=SenLégal
PRICE_PRO_AMOUNT_XOF=9900
PRICE_PRO_DURATION_MONTHS=1
