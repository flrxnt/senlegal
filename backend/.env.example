# --- Database --------------------------------------------------------------
DATABASE_URL="postgresql://senlegal:senlegal@localhost:5433/senlegal?schema=public"

# --- App -------------------------------------------------------------------
NODE_ENV=development
PORT=3001
APP_PUBLIC_URL="http://localhost:3001"
WEB_PUBLIC_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"

# --- Auth ------------------------------------------------------------------
JWT_SECRET="change-me-min-32-characters-please-rotate"
JWT_EXPIRES_IN="7d"
BCRYPT_ROUNDS=12

# Bootstrap admin (created/updated by `bun run seed`)
ADMIN_EMAIL="admin@senlegal.sn"
ADMIN_PASSWORD="ChangeMeNow!2026"
ADMIN_NAME="Administrateur SenLégal"

# --- AI service (FastAPI from /ai) -----------------------------------------
AI_BASE_URL="http://localhost:8001"
AI_API_KEY=""
AI_ADMIN_TOKEN="change-me"
AI_TIMEOUT_MS="60000"

# --- Object storage (MinIO en dev, S3 en prod) -----------------------------
S3_ENDPOINT="http://localhost:9000"
S3_PUBLIC_URL="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="senlegal"
S3_SECRET_KEY="senlegal_dev_secret_change_me"
S3_BUCKET="senlegal"
S3_FORCE_PATH_STYLE="true"

# Quotas
MAX_AVATAR_SIZE_MB=2
MAX_USER_DOCUMENT_SIZE_MB=25
MAX_RAG_DOCUMENT_SIZE_MB=100
MAX_CHAT_ATTACHMENT_SIZE_MB=10
FREE_DAILY_CHAT_LIMIT=5
FREE_USER_STORAGE_MB=50

# --- Mailer (SMTP) ---------------------------------------------------------
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="SenLégal <no-reply@senlegal.local>"

# --- Subscriptions cron ----------------------------------------------------
SUBSCRIPTIONS_SCHEDULER_ENABLED="true"
BACKUP_SCHEDULER_ENABLED="false"

# --- Payments (PayDunya) ---------------------------------------------------
PAYDUNYA_MASTER_KEY=""
PAYDUNYA_PRIVATE_KEY=""
PAYDUNYA_TOKEN=""
PAYDUNYA_MODE="test"
PAYDUNYA_STORE_NAME="SenLégal"
PAYDUNYA_STORE_LOGO_URL=""
PAYDUNYA_STORE_WEBSITE_URL=""

# Pricing (XOF, mois)
PRICE_PRO_AMOUNT_XOF=9900
PRICE_PRO_DURATION_MONTHS=1
